# ==========================================================================
# Reality Lock backend — environment template.
# Copy to `.env` (gitignored) and adjust. Every value is OPTIONAL in dev; the
# server falls back to the documented defaults in src/config/index.js. Nothing
# is hardcoded in source — all runtime config is read from here / process.env.
# ==========================================================================

NODE_ENV=development
PORT=3000

# Comma-separated CORS allow-list. '*' is convenient for local dev only.
ALLOWED_ORIGINS=*

# Max proof-package JSON body size, in bytes (default 2 MiB).
MAX_JSON_BYTES=2097152

# Absolute path override for the shared proof-package schema.
# Defaults to <repo>/docs/design/proof-package.schema.json — normally leave unset.
# PROOF_SCHEMA_PATH=

# Absolute path override for the reference proof package checked by
# `npm run validate:schema`.
# Defaults to <repo>/docs/design/examples/proof-package.example.json.
# PROOF_EXAMPLE_PATH=

# --- Firebase (Phase 5 — leave blank until configured; see ../SETUP.md) ---
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
