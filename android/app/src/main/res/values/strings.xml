<?xml version="1.0" encoding="utf-8"?>
<!--
    All user-facing text lives here, never inline in Compose. Keeping it in one
    place is what makes the UI reviewable and translatable; a literal in a
    composable is invisible to both.
-->
<resources>
    <string name="app_name">Reality Lock</string>

    <!-- ==================== Capture screen: tabs ==================== -->
    <string name="tab_capture">Capture</string>
    <string name="tab_history">History (%1$d)</string>
    <string name="tab_device">Device</string>

    <!-- ==================== Capture tab ==================== -->
    <string name="capture_location_denied_warning">Location is not granted — events will be recorded without a location proof.</string>
