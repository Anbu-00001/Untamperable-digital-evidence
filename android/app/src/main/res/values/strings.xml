    <string name="capture_in_progress">Capturing…</string>
    <string name="capture_action">Capture event</string>
    <string name="capture_dismiss_error">Dismiss</string>
    <string name="capture_last_capture">Last capture</string>

    <!-- ==================== Permission rationale ====================
         Itemized per permission (research/06 §3): each one states exactly what
         is recorded and why, rather than one opaque bundled prompt. -->
    <string name="permissions_title">Permissions needed</string>
    <string name="permissions_camera_rationale">Camera (required) — captures the photo that the proof is built from. Media is captured in-app only; existing gallery photos can never be imported.</string>
    <string name="permissions_location_rationale">Location (optional) — records where the event happened so the proof can include a location claim. Without it, captures still work and the location is recorded as absent, never guessed.</string>
    <string name="permissions_motion_note">Motion sensors are read only while this screen is open, and only around the moment of capture.</string>
    <string name="permissions_grant_camera">Grant camera access</string>
    <string name="permissions_grant_all">Grant access</string>

    <!-- ==================== History tab ==================== -->
    <string name="history_empty">No events captured yet.</string>
    <string name="history_delete">Delete</string>

